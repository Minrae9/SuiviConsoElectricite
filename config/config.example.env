# ============================================================
# Configuration Mint-Énergie - Fichier exemple
# ============================================================
# 1. Copiez ce fichier vers config/.env
#    cp config/config.example.env config/.env
# 2. Remplissez vos identifiants ci-dessous
# 3. Ne commitez JAMAIS le fichier config/.env
# ============================================================

# Identifiants de connexion à l'espace client Mint-Énergie
MINT_EMAIL=votre.email@exemple.com
MINT_PASSWORD=votre_mot_de_passe

# URL de base du site Mint-Énergie
MINT_BASE_URL=https://client.mint-energie.com

# Mode headless du navigateur (true = invisible, false = fenêtre visible pour debug)
MINT_HEADLESS=true
